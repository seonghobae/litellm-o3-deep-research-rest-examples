# Example configuration for local development.
#
# Copy this file to ~/.env and fill in your own values. Do NOT commit
# real API keys or production URLs.

# Upstream LiteLLM Proxy settings (required by all three examples)
LITELLM_API_KEY=sk-your-lite-llm-api-key
LITELLM_BASE_URL=https://localhost:4000/v1
LITELLM_MODEL=o3-deep-research

# Relay server settings (only used when running the relay/ example)
# These are optional — the values below are the defaults.
RELAY_HOST=127.0.0.1
RELAY_PORT=8080
RELAY_TIMEOUT_SECONDS=30

# Java relay caller settings (only used when --target relay is passed to Java)
# Optional — the value below is the default.
RELAY_BASE_URL=http://127.0.0.1:8080
